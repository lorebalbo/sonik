{
  "schemaVersion": 1,
  "device": {
    "manufacturer": "Reloop",
    "product": ".*Contour.*Interface.*Edition.*",
    "match": { "midiName": ".*Contour.*Interface.*Edition.*" }
  },
  "modifiers": [
    {
      "id": "shift",
      "binding": { "channel": 1, "status": "note", "data1": 63, "style": "momentary" }
    }
  ],
  "bindings": [

    { "target": "deck.A.transport.play",
      "midi": { "channel": 1, "status": "note", "data1": 22 },
      "transform": "momentary",
      "feedback": { "channel": 1, "status": "note", "data1": 22, "onValue": 127, "offValue": 0 } },
    { "target": "deck.A.transport.cue",
      "midi": { "channel": 1, "status": "note", "data1": 23 },
      "transform": "momentary",
      "feedback": { "channel": 1, "status": "note", "data1": 23, "onValue": 127, "offValue": 0 } },
    { "target": "deck.A.transport.sync",
      "midi": { "channel": 1, "status": "note", "data1": 24 },
      "transform": "momentary",
      "feedback": { "channel": 1, "status": "note", "data1": 24, "onValue": 127, "offValue": 0 } },

    { "target": "deck.A.pitchFader", "midi": { "channel": 1, "status": "cc", "data1": 9 },  "transform": "linear" },
    { "target": "deck.A.gain",       "midi": { "channel": 1, "status": "cc", "data1": 16 }, "transform": "linear" },
    { "target": "deck.A.eq.high",    "midi": { "channel": 1, "status": "cc", "data1": 17 }, "transform": "linear" },
    { "target": "deck.A.eq.mid",     "midi": { "channel": 1, "status": "cc", "data1": 18 }, "transform": "linear" },
    { "target": "deck.A.eq.low",     "midi": { "channel": 1, "status": "cc", "data1": 19 }, "transform": "linear" },

    { "target": "deck.A.jog.touch",   "midi": { "channel": 1, "status": "note", "data1": 18 }, "transform": "momentary" },
    { "target": "deck.A.jog.scratch", "midi": { "channel": 1, "status": "cc",   "data1": 22 }, "transform": "signedBitDelta" },
    { "target": "deck.A.jog.bend",    "midi": { "channel": 1, "status": "cc",   "data1": 23 }, "transform": "signedBitDelta" },

    { "target": "deck.A.loop.in",     "midi": { "channel": 1, "status": "note", "data1": 32 }, "transform": "momentary" },
    { "target": "deck.A.loop.out",    "midi": { "channel": 1, "status": "note", "data1": 33 }, "transform": "momentary" },
    { "target": "deck.A.loop.toggle", "midi": { "channel": 1, "status": "note", "data1": 34 }, "transform": "toggle",
      "feedback": { "channel": 1, "status": "note", "data1": 34, "onValue": 127, "offValue": 0 } },
    { "target": "deck.A.loop.size.halve",  "midi": { "channel": 1, "status": "note", "data1": 35 }, "transform": "momentary" },
    { "target": "deck.A.loop.size.double", "midi": { "channel": 1, "status": "note", "data1": 36 }, "transform": "momentary" },

    { "target": "deck.A.beatjump.minus.1", "midi": { "channel": 1, "status": "note", "data1": 35 }, "modifier": "shift", "transform": "momentary" },
    { "target": "deck.A.beatjump.plus.1",  "midi": { "channel": 1, "status": "note", "data1": 36 }, "modifier": "shift", "transform": "momentary" },

    { "target": "deck.A.hotcue.1.trigger", "midi": { "channel": 1, "status": "note", "data1": 48 }, "transform": "momentary",
      "feedback": { "channel": 1, "status": "note", "data1": 48, "onValue": 127, "offValue": 0 } },
    { "target": "deck.A.hotcue.2.trigger", "midi": { "channel": 1, "status": "note", "data1": 49 }, "transform": "momentary",
      "feedback": { "channel": 1, "status": "note", "data1": 49, "onValue": 127, "offValue": 0 } },
    { "target": "deck.A.hotcue.3.trigger", "midi": { "channel": 1, "status": "note", "data1": 50 }, "transform": "momentary",
      "feedback": { "channel": 1, "status": "note", "data1": 50, "onValue": 127, "offValue": 0 } },
    { "target": "deck.A.hotcue.4.trigger", "midi": { "channel": 1, "status": "note", "data1": 51 }, "transform": "momentary",
      "feedback": { "channel": 1, "status": "note", "data1": 51, "onValue": 127, "offValue": 0 } },

    { "target": "deck.A.hotcue.1.delete", "midi": { "channel": 1, "status": "note", "data1": 48 }, "modifier": "shift", "transform": "momentary" },
    { "target": "deck.A.hotcue.2.delete", "midi": { "channel": 1, "status": "note", "data1": 49 }, "modifier": "shift", "transform": "momentary" },
    { "target": "deck.A.hotcue.3.delete", "midi": { "channel": 1, "status": "note", "data1": 50 }, "modifier": "shift", "transform": "momentary" },
    { "target": "deck.A.hotcue.4.delete", "midi": { "channel": 1, "status": "note", "data1": 51 }, "modifier": "shift", "transform": "momentary" },

    { "target": "deck.B.transport.play",
      "midi": { "channel": 2, "status": "note", "data1": 22 },
      "transform": "momentary",
      "feedback": { "channel": 2, "status": "note", "data1": 22, "onValue": 127, "offValue": 0 } },
    { "target": "deck.B.transport.cue",
      "midi": { "channel": 2, "status": "note", "data1": 23 },
      "transform": "momentary",
      "feedback": { "channel": 2, "status": "note", "data1": 23, "onValue": 127, "offValue": 0 } },
    { "target": "deck.B.transport.sync",
      "midi": { "channel": 2, "status": "note", "data1": 24 },
      "transform": "momentary",
      "feedback": { "channel": 2, "status": "note", "data1": 24, "onValue": 127, "offValue": 0 } },

    { "target": "deck.B.pitchFader", "midi": { "channel": 2, "status": "cc", "data1": 9 },  "transform": "linear" },
    { "target": "deck.B.gain",       "midi": { "channel": 2, "status": "cc", "data1": 16 }, "transform": "linear" },
    { "target": "deck.B.eq.high",    "midi": { "channel": 2, "status": "cc", "data1": 17 }, "transform": "linear" },
    { "target": "deck.B.eq.mid",     "midi": { "channel": 2, "status": "cc", "data1": 18 }, "transform": "linear" },
    { "target": "deck.B.eq.low",     "midi": { "channel": 2, "status": "cc", "data1": 19 }, "transform": "linear" },

    { "target": "deck.B.jog.touch",   "midi": { "channel": 2, "status": "note", "data1": 18 }, "transform": "momentary" },
    { "target": "deck.B.jog.scratch", "midi": { "channel": 2, "status": "cc",   "data1": 22 }, "transform": "signedBitDelta" },
    { "target": "deck.B.jog.bend",    "midi": { "channel": 2, "status": "cc",   "data1": 23 }, "transform": "signedBitDelta" },

    { "target": "deck.B.loop.in",     "midi": { "channel": 2, "status": "note", "data1": 32 }, "transform": "momentary" },
    { "target": "deck.B.loop.out",    "midi": { "channel": 2, "status": "note", "data1": 33 }, "transform": "momentary" },
    { "target": "deck.B.loop.toggle", "midi": { "channel": 2, "status": "note", "data1": 34 }, "transform": "toggle",
      "feedback": { "channel": 2, "status": "note", "data1": 34, "onValue": 127, "offValue": 0 } },
    { "target": "deck.B.loop.size.halve",  "midi": { "channel": 2, "status": "note", "data1": 35 }, "transform": "momentary" },
    { "target": "deck.B.loop.size.double", "midi": { "channel": 2, "status": "note", "data1": 36 }, "transform": "momentary" },

    { "target": "deck.B.beatjump.minus.1", "midi": { "channel": 2, "status": "note", "data1": 35 }, "modifier": "shift", "transform": "momentary" },
    { "target": "deck.B.beatjump.plus.1",  "midi": { "channel": 2, "status": "note", "data1": 36 }, "modifier": "shift", "transform": "momentary" },

    { "target": "deck.B.hotcue.1.trigger", "midi": { "channel": 2, "status": "note", "data1": 48 }, "transform": "momentary",
      "feedback": { "channel": 2, "status": "note", "data1": 48, "onValue": 127, "offValue": 0 } },
    { "target": "deck.B.hotcue.2.trigger", "midi": { "channel": 2, "status": "note", "data1": 49 }, "transform": "momentary",
      "feedback": { "channel": 2, "status": "note", "data1": 49, "onValue": 127, "offValue": 0 } },
    { "target": "deck.B.hotcue.3.trigger", "midi": { "channel": 2, "status": "note", "data1": 50 }, "transform": "momentary",
      "feedback": { "channel": 2, "status": "note", "data1": 50, "onValue": 127, "offValue": 0 } },
    { "target": "deck.B.hotcue.4.trigger", "midi": { "channel": 2, "status": "note", "data1": 51 }, "transform": "momentary",
      "feedback": { "channel": 2, "status": "note", "data1": 51, "onValue": 127, "offValue": 0 } },

    { "target": "deck.B.hotcue.1.delete", "midi": { "channel": 2, "status": "note", "data1": 48 }, "modifier": "shift", "transform": "momentary" },
    { "target": "deck.B.hotcue.2.delete", "midi": { "channel": 2, "status": "note", "data1": 49 }, "modifier": "shift", "transform": "momentary" },
    { "target": "deck.B.hotcue.3.delete", "midi": { "channel": 2, "status": "note", "data1": 50 }, "modifier": "shift", "transform": "momentary" },
    { "target": "deck.B.hotcue.4.delete", "midi": { "channel": 2, "status": "note", "data1": 51 }, "modifier": "shift", "transform": "momentary" },

    { "target": "mixer.crossfader", "midi": { "channel": 16, "status": "cc", "data1": 7 }, "transform": "linear" }
  ]
}
